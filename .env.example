# Anthropic API key - required for AI tools (ask_claude, plan_task, etc.)
ANTHROPIC_API_KEY=sk-ant-...

# Server configuration (optional)
SERVER_HOST=0.0.0.0
PORT=8000

# Comma-separated list of Render service URLs to monitor health
# RENDER_SERVERS=https://my-service.onrender.com,https://another.onrender.com

# Set to "true" automatically by Render.com. Disables local-only tools.
# Do not set this manually unless testing Render mode locally.
# RENDER=true
